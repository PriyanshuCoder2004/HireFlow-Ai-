  "universal_guidelines": [
    "DO NOT use generic centered layouts. Use asymmetry.",
    "DO NOT use 'Inter' for headings. Use 'Manrope'.",
    "DO NOT use teal/purple gradients. Use the defined 'Electric Obsidian' palette.",
    "ALWAYS add 'data-testid' to interactive elements.",
    "ALWAYS use 'sonner' for toasts.",
    "Use 'lucide-react' for icons.",
    "Ensure 3:1 contrast ratio for large text and 4.5:1 for normal text.",
    "Use 'lenis' for smooth scrolling on the marketing page.",
    "Dashboard must be dense and data-rich, not airy and empty."
  ],
  "instructions_to_main_agent": {
    "step_1": "Update /app/frontend/src/index.css with the provided HSL variables.",
    "step_2": "Install necessary dependencies: lucide-react, sonner, @lenis/react, clsx, tailwind-merge.",
    "step_3": "Create the layout components (Navbar, Sidebar) using the 'glass_panel' style.",
    "step_4": "Implement the Landing Page using the 'marketing_grid' and 'hero_main' image.",
    "step_5": "Implement the Dashboard using the 'dashboard_grid' and 'card_base' styles."
  }
}