{
  "identity": {
    "name": "HireFlow AI",
    "archetype": "The Performance Pro",
    "tone": "Empowering, Precision-Focused, High-Contrast",
    "mission": "To give job seekers an unfair advantage through AI-driven clarity and speed."
  },
  "typography": {
    "fonts": {
      "heading": "Manrope",
      "body": "Inter",
      "mono": "JetBrains Mono"
    },
    "weights": {
      "heading": "font-bold tracking-tight",
      "body": "font-normal tracking-normal"
    },
    "scale": {
      "h1": "text-4xl md:text-6xl lg:text-7xl font-extrabold tracking-tighter",
      "h2": "text-3xl md:text-4xl font-bold tracking-tight",
      "h3": "text-2xl font-semibold tracking-tight",
      "p": "text-base md:text-lg leading-relaxed text-muted-foreground"
    }
  },
