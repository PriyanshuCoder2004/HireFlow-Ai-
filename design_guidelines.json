  "layout_strategies": {
    "marketing_grid": "grid grid-cols-1 md:grid-cols-12 gap-8 md:gap-12 p-6 md:p-12",
    "dashboard_grid": "grid grid-cols-1 md:grid-cols-4 gap-6 p-6",
    "bento_hero": "col-span-full md:col-span-8 row-span-2",
    "bento_sidebar": "col-span-full md:col-span-4 row-span-2",
    "container_padding": "px-6 md:px-12 lg:px-24 py-12 md:py-24"
  },
  "component_styles": {
    "radius": "0.5rem",
    "button_primary": "bg-primary text-primary-foreground hover:bg-primary/90 shadow-lg hover:shadow-primary/25 transition-all duration-300",
    "card_base": "bg-card text-card-foreground border border-border shadow-sm hover:shadow-md transition-all duration-300",
    "input_base": "bg-background border-input focus:ring-2 focus:ring-primary/20 transition-all duration-200",
    "glass_panel": "bg-background/70 backdrop-blur-xl border border-white/10 shadow-xl"
  },
  "visual_enhancers": {
    "gradients": {
      "hero_glow": "bg-gradient-to-tr from-primary/20 via-background to-background",
      "text_gradient": "bg-clip-text text-transparent bg-gradient-to-r from-primary to-purple-500"
    },
    "textures": {
      "noise": "opacity-[0.03] pointer-events-none fixed inset-0 z-50 bg-[url('https://grainy-gradients.vercel.app/noise.svg')]"
    },
    "animations": {
      "fade_in_up": "animate-in fade-in slide-in-from-bottom-8 duration-700",
      "hover_lift": "hover:-translate-y-1 transition-transform duration-300"
    }
  },
